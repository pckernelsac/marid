# ── Madrid Dental Studio · Variables de producción ────────────────────
# Copia este archivo a `.env.production` y rellena los valores reales,
# o define estas variables en la UI de Dokploy (recomendado).
# NUNCA subas `.env.production` con secretos reales a git.

PROJECT_NAME="Madrid Dental Studio"
ENVIRONMENT=production

# ── PostgreSQL (servicio ya creado en Dokploy) ────────────────────────
POSTGRES_SERVER=app-madrid-db-qfgme1
POSTGRES_PORT=5432
POSTGRES_USER=madrid_user
POSTGRES_PASSWORD=__pon-aqui-tu-password__
POSTGRES_DB=madrid

# ── Seguridad ─────────────────────────────────────────────────────────
# Genera uno nuevo con:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=__genera-una-cadena-larga-y-aleatoria__
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────
# Mismo origen (nginx hace de proxy), así que puede ir vacío.
BACKEND_CORS_ORIGINS=[]

# ── Primer superusuario (se crea en el primer arranque) ───────────────
FIRST_SUPERUSER_EMAIL=admin@madriddental.studio
FIRST_SUPERUSER_PASSWORD=__cambia-esta-password__
